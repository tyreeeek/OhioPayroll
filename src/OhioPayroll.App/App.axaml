<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OhioPayroll.App.App"
             xmlns:local="using:OhioPayroll.App"
             xmlns:converters="using:OhioPayroll.App.Converters"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

        <!-- Modern Design System -->
        <StyleInclude Source="avares://OhioPayroll/Styles/ModernColors.axaml"/>
        <StyleInclude Source="avares://OhioPayroll/Styles/ModernButtons.axaml"/>
        <StyleInclude Source="avares://OhioPayroll/Styles/ModernControls.axaml"/>

        <!-- Accent = Primary for backward compatibility -->
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        <Style Selector="Button.accent:pointerover">
            <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
        </Style>
    </Application.Styles>
</Application>
