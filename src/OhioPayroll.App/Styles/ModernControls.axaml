<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════
         PRODUCTION SaaS CONTROL STYLES
         Clean white, crisp borders, professional spacing
         ══════════════════════════════════════════════════ -->

    <!-- ── Card ────────────────────────────────────────── -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="BoxShadow" Value="0 1 3 0 #0D000000, 0 1 2 0 #06000000"/>
    </Style>

    <!-- ── Typography ──────────────────────────────────── -->
    <Style Selector="TextBlock.page-title">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="700"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="LetterSpacing" Value="-0.5"/>
    </Style>

    <Style Selector="TextBlock.page-subtitle">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="400"/>
        <Setter Property="Margin" Value="0,0,0,24"/>
    </Style>

    <Style Selector="TextBlock.section-header">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- ── Form Controls ───────────────────────────────── -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource TextMutedBrush}"/>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <Style Selector="TextBlock.label">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="500"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- ── CheckBox ────────────────────────────────────── -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="CheckBox /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
    </Style>
    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
    </Style>

    <!-- ── DataGrid — Clean Professional ───────────────── -->
    <Style Selector="DataGrid">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="RowBackground" Value="Transparent"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="RowHeight" Value="44"/>
    </Style>
    <Style Selector="DataGridRow">
        <Setter Property="Margin" Value="0"/>
    </Style>
    <Style Selector="DataGridRow /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="Transparent"/>
    </Style>
    <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{StaticResource SurfaceHoverBrush}"/>
    </Style>
    <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{StaticResource PrimaryLightBrush}"/>
    </Style>
    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Height" Value="40"/>
    </Style>
    <Style Selector="DataGridCell">
        <Setter Property="Padding" Value="12,0"/>
    </Style>

    <!-- ── Stat Card ───────────────────────────────────── -->
    <Style Selector="Border.stat-card">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20,16"/>
        <Setter Property="BoxShadow" Value="0 1 3 0 #0D000000, 0 1 2 0 #06000000"/>
    </Style>
    <Style Selector="Border.stat-card TextBlock.stat-value">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="700"/>
        <Setter Property="LetterSpacing" Value="-0.5"/>
    </Style>
    <Style Selector="Border.stat-card TextBlock.stat-label">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="LetterSpacing" Value="0.5"/>
    </Style>

    <!-- ── Badges ──────────────────────────────────────── -->
    <Style Selector="Border.badge-success">
        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style Selector="Border.badge-success TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="600"/>
    </Style>

    <Style Selector="Border.badge-warning">
        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style Selector="Border.badge-warning TextBlock">
        <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="600"/>
    </Style>

    <Style Selector="Border.badge-danger">
        <Setter Property="Background" Value="{StaticResource DangerLightBrush}"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style Selector="Border.badge-danger TextBlock">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="600"/>
    </Style>

    <!-- ── Alerts ──────────────────────────────────────── -->
    <Style Selector="Border.alert-error">
        <Setter Property="Background" Value="{StaticResource DangerLightBrush}"/>
        <Setter Property="BorderBrush" Value="#FECACA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16,12"/>
    </Style>
    <Style Selector="Border.alert-success">
        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
        <Setter Property="BorderBrush" Value="#A7F3D0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16,12"/>
    </Style>
    <Style Selector="Border.alert-warning">
        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
        <Setter Property="BorderBrush" Value="#FDE68A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16,12"/>
    </Style>

    <!-- ── Divider ─────────────────────────────────────── -->
    <Style Selector="Separator">
        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,16"/>
    </Style>

    <!-- ── Help / Error Text ───────────────────────────── -->
    <Style Selector="TextBlock.help-text">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="TextBlock.error-text">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="500"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
</Styles>
