<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style>
        <Style.Resources>
            <!-- ══════════════════════════════════════════════════
                 PURE WHITE MODE — Clean Modern SaaS
                 ══════════════════════════════════════════════════ -->

            <!-- Primary — Vivid Blue -->
            <Color x:Key="Light_Primary">#2563EB</Color>
            <Color x:Key="Light_PrimaryHover">#1D4ED8</Color>
            <Color x:Key="Light_PrimaryActive">#1E40AF</Color>
            <Color x:Key="Light_PrimaryLight">#EFF6FF</Color>

            <!-- Semantic -->
            <Color x:Key="Light_Success">#16A34A</Color>
            <Color x:Key="Light_SuccessHover">#15803D</Color>
            <Color x:Key="Light_SuccessLight">#F0FDF4</Color>

            <Color x:Key="Light_Danger">#DC2626</Color>
            <Color x:Key="Light_DangerHover">#B91C1C</Color>
            <Color x:Key="Light_DangerLight">#FEF2F2</Color>

            <Color x:Key="Light_Warning">#EA580C</Color>
            <Color x:Key="Light_WarningHover">#C2410C</Color>
            <Color x:Key="Light_WarningLight">#FFF7ED</Color>

            <!-- Surfaces — PURE WHITE -->
            <Color x:Key="Light_Background">#FFFFFF</Color>
            <Color x:Key="Light_Surface">#FFFFFF</Color>
            <Color x:Key="Light_SurfaceHover">#F5F5F5</Color>
            <Color x:Key="Light_Border">#E2E8F0</Color>
            <Color x:Key="Light_BorderLight">#F1F5F9</Color>
            <Color x:Key="Light_Sidebar">#F8FAFC</Color>

            <!-- Typography — Strong contrast -->
            <Color x:Key="Light_TextPrimary">#0F172A</Color>
            <Color x:Key="Light_TextSecondary">#64748B</Color>
            <Color x:Key="Light_TextMuted">#94A3B8</Color>

            <!-- ══════════════════════════════════════════════════
                 DARK MODE (toggle support)
                 ══════════════════════════════════════════════════ -->
            <Color x:Key="Dark_Primary">#60A5FA</Color>
            <Color x:Key="Dark_PrimaryHover">#3B82F6</Color>
            <Color x:Key="Dark_PrimaryActive">#2563EB</Color>

            <Color x:Key="Dark_Success">#4ADE80</Color>
            <Color x:Key="Dark_SuccessHover">#22C55E</Color>

            <Color x:Key="Dark_Danger">#F87171</Color>
            <Color x:Key="Dark_DangerHover">#EF4444</Color>

            <Color x:Key="Dark_Warning">#FB923C</Color>
            <Color x:Key="Dark_WarningHover">#F97316</Color>

            <Color x:Key="Dark_Background">#0F172A</Color>
            <Color x:Key="Dark_Surface">#1E293B</Color>
            <Color x:Key="Dark_SurfaceHover">#334155</Color>
            <Color x:Key="Dark_Border">#334155</Color>
            <Color x:Key="Dark_Sidebar">#0F172A</Color>

            <Color x:Key="Dark_TextPrimary">#F8FAFC</Color>
            <Color x:Key="Dark_TextSecondary">#94A3B8</Color>
            <Color x:Key="Dark_TextMuted">#64748B</Color>

            <!-- ══════════════════════════════════════════════════
                 Active Theme Brushes (Default: White)
                 ══════════════════════════════════════════════════ -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Light_Primary}"/>
            <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource Light_PrimaryHover}"/>
            <SolidColorBrush x:Key="PrimaryActiveBrush" Color="{StaticResource Light_PrimaryActive}"/>
            <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource Light_PrimaryLight}"/>

            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Light_Success}"/>
            <SolidColorBrush x:Key="SuccessHoverBrush" Color="{StaticResource Light_SuccessHover}"/>
            <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource Light_SuccessLight}"/>

            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Light_Danger}"/>
            <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource Light_DangerHover}"/>
            <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource Light_DangerLight}"/>

            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Light_Warning}"/>
            <SolidColorBrush x:Key="WarningHoverBrush" Color="{StaticResource Light_WarningHover}"/>
            <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource Light_WarningLight}"/>

            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Light_Background}"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Light_Surface}"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource Light_SurfaceHover}"/>
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Light_Border}"/>
            <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource Light_BorderLight}"/>
            <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource Light_Sidebar}"/>

            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource Light_TextPrimary}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource Light_TextSecondary}"/>
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource Light_TextMuted}"/>
        </Style.Resources>
    </Style>

    <!-- Dark Mode Override -->
    <Style Selector="Window.dark-theme">
        <Style.Resources>
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Dark_Primary}"/>
            <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource Dark_PrimaryHover}"/>
            <SolidColorBrush x:Key="PrimaryActiveBrush" Color="{StaticResource Dark_PrimaryActive}"/>

            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Dark_Success}"/>
            <SolidColorBrush x:Key="SuccessHoverBrush" Color="{StaticResource Dark_SuccessHover}"/>

            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Dark_Danger}"/>
            <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource Dark_DangerHover}"/>

            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Dark_Warning}"/>
            <SolidColorBrush x:Key="WarningHoverBrush" Color="{StaticResource Dark_WarningHover}"/>

            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Dark_Background}"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Dark_Surface}"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource Dark_SurfaceHover}"/>
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Dark_Border}"/>
            <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource Dark_Sidebar}"/>

            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource Dark_TextPrimary}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource Dark_TextSecondary}"/>
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource Dark_TextMuted}"/>
        </Style.Resources>
    </Style>
</Styles>
