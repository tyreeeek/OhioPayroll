<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:OhioPayroll.App.Controls"
             x:Class="OhioPayroll.App.Controls.LoadingOverlay"
             x:DataType="controls:LoadingOverlay">

    <!--
        Loading Overlay Control

        Usage: Add this to any view that needs loading state:

        <controls:LoadingOverlay IsVisible="{Binding IsLoading}"
                                 LoadingMessage="{Binding LoadingMessage}" />

        It will display a semi-transparent overlay with a spinner and message.
    -->

    <Border Background="#CC000000"
            IsVisible="{Binding $parent[UserControl].IsVisible}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">

            <!-- Animated spinner using PathIcon -->
            <Viewbox Width="48" Height="48">
                <PathIcon Data="M12,4V2A10,10 0 0,0 2,12H4A8,8 0 0,1 12,4Z"
                          Foreground="White">
                    <PathIcon.RenderTransform>
                        <RotateTransform />
                    </PathIcon.RenderTransform>
                    <PathIcon.Styles>
                        <Style Selector="PathIcon">
                            <Style.Animations>
                                <Animation Duration="0:0:1" IterationCount="Infinite">
                                    <KeyFrame Cue="0%">
                                        <Setter Property="(RotateTransform.Angle)" Value="0"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="100%">
                                        <Setter Property="(RotateTransform.Angle)" Value="360"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </PathIcon.Styles>
                </PathIcon>
            </Viewbox>

            <!-- Loading message -->
            <TextBlock Text="{Binding LoadingMessage}"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Medium"
                       TextAlignment="Center"
                       MaxWidth="400"
                       TextWrapping="Wrap" />

        </StackPanel>
    </Border>

</UserControl>
