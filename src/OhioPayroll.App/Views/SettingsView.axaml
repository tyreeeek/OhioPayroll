<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OhioPayroll.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:enums="using:OhioPayroll.Core.Models.Enums"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="900"
             x:Class="OhioPayroll.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">


    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="32" Margin="0,0,0,32">

            <!-- Page Title -->
            <TextBlock Text="Settings" Classes="page-title"/>

            <!-- Company Information -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Company Information" Classes="section-header"/>

                    <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12">

                        <!-- Company Name -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Company Name" Classes="label" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding CompanyName}" Watermark="Enter company name"/>

                        <!-- EIN -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="EIN" Classes="label" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Ein}" Watermark="XX-XXXXXXX"/>

                        <!-- State Withholding ID -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="State Withholding ID" Classes="label" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding StateWithholdingId}" Watermark="Ohio employer withholding account number"/>

                        <!-- Address -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Address" Classes="label" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding Address}" Watermark="Street address"/>

                        <!-- City -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="City" Classes="label" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding City}" Watermark="City"/>

                        <!-- State -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="State" Classes="label" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="5" Grid.Column="1" Text="{Binding State}" Watermark="OH" MaxLength="2"/>

                        <!-- Zip Code -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Zip Code" Classes="label" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="6" Grid.Column="1" Text="{Binding ZipCode}" Watermark="XXXXX" MaxLength="10"/>

                        <!-- Phone -->
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Phone" Classes="label" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="7" Grid.Column="1" Text="{Binding Phone}" Watermark="(XXX) XXX-XXXX"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Payroll Settings -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Payroll Settings" Classes="section-header"/>

                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12">

                        <!-- Pay Frequency -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Pay Frequency" Classes="label" VerticalAlignment="Center"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1"
                                   ItemsSource="{Binding AvailablePayFrequencies}"
                                   SelectedItem="{Binding PayFrequency}"
                                   MinWidth="300"/>

                        <!-- Current Tax Year -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Current Tax Year" Classes="label" VerticalAlignment="Center"/>
                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                       Value="{Binding CurrentTaxYear}"
                                       Minimum="2020" Maximum="2099"
                                       FormatString="0"
                                       MinWidth="300"/>

                        <!-- Local Tax Rate -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Local Tax Rate (%)" Classes="label" VerticalAlignment="Center"/>
                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                       Value="{Binding LocalTaxRate}"
                                       Minimum="0" Maximum="1"
                                       Increment="0.001"
                                       FormatString="P3"
                                       MinWidth="300"/>

                        <!-- School District Rate -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="School District Rate (%)" Classes="label" VerticalAlignment="Center"/>
                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                       Value="{Binding SchoolDistrictRate}"
                                       Minimum="0" Maximum="1"
                                       Increment="0.001"
                                       FormatString="P3"
                                       MinWidth="300"/>

                        <!-- School District Code -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="School District Code" Classes="label" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="4" Grid.Column="1"
                                   Text="{Binding SchoolDistrictCode}"
                                   Watermark="e.g., 0401"/>

                        <!-- SUTA Rate -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="SUTA Rate (%)" Classes="label" VerticalAlignment="Center"/>
                        <NumericUpDown Grid.Row="5" Grid.Column="1"
                                       Value="{Binding SutaRate}"
                                       Minimum="0" Maximum="1"
                                       Increment="0.001"
                                       FormatString="P3"
                                       MinWidth="300"/>

                        <!-- Backup Directory -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Backup Directory" Classes="label" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="6" Grid.Column="1"
                                   Text="{Binding BackupDirectory}"
                                   Watermark="C:\Backups\Payroll"/>

                        <!-- Next Check Number -->
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Next Check Number" Classes="label" VerticalAlignment="Center"/>
                        <NumericUpDown Grid.Row="7" Grid.Column="1"
                                       Value="{Binding NextCheckNumber}"
                                       Minimum="1" Maximum="999999"
                                       FormatString="0"
                                       MinWidth="300"/>

                        <!-- Check Offset X -->
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Check Offset X" Classes="label" VerticalAlignment="Center"/>
                        <NumericUpDown Grid.Row="8" Grid.Column="1"
                                       Value="{Binding CheckOffsetX}"
                                       Increment="0.1"
                                       FormatString="0.0"
                                       MinWidth="300"/>

                        <!-- Check Offset Y -->
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Check Offset Y" Classes="label" VerticalAlignment="Center"/>
                        <NumericUpDown Grid.Row="9" Grid.Column="1"
                                       Value="{Binding CheckOffsetY}"
                                       Increment="0.1"
                                       FormatString="0.0"
                                       MinWidth="300"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Backup & Restore -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Backup &amp; Restore" Classes="section-header"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Last Backup:" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding LastBackupDisplay}"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <Button Content="Backup Now"
                                Command="{Binding BackupNowCommand}"
                                Padding="24,10"
                                Classes="primary"/>

                        <Button Content="Open Backup Folder"
                                Command="{Binding OpenBackupFolderCommand}"
                                Padding="24,10"
                                Classes="secondary"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Application Updates -->
            <Border Classes="card">
                <StackPanel Spacing="20">
                    <TextBlock Text="Application Updates" Classes="section-header"/>

                    <CheckBox Content="Automatically check for updates on startup"
                              IsChecked="{Binding AutoCheckForUpdates}"/>

                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                        <!-- Update Channel -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Update Channel:" Classes="label" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  ItemsSource="{Binding UpdateChannels}"
                                  SelectedItem="{Binding SelectedUpdateChannel}"
                                  MinWidth="220"
                                  HorizontalAlignment="Left"/>

                        <!-- Current Version -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Current Version:" Classes="label" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding CurrentVersion}"
                                   FontWeight="600"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>

                        <!-- Last Check -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Check:" Classes="label" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding LastUpdateCheckText}"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>

                    <Button Content="Check for Updates Now"
                            Command="{Binding CheckForUpdatesCommand}"
                            IsEnabled="{Binding !IsCheckingForUpdates}"
                            Padding="24,10"
                            Classes="primary"/>

                    <!-- Update Available Panel -->
                    <Border IsVisible="{Binding AvailableUpdate, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Background="{StaticResource PrimaryLightBrush}"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Update Available!" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="{Binding AvailableUpdate.ReleaseName}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding AvailableUpdate.ReleaseNotes}"
                                       TextWrapping="Wrap"
                                       MaxHeight="150"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Button Content="Download and Install Update"
                                    Classes="primary"
                                    Padding="16,8"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Note: Updates are downloaded from GitHub. Your data and settings are preserved during updates."
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Save Button & Status -->
            <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Left">
                <Button Content="Save Settings"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding HasChanges}"
                        Padding="24,10"
                        Classes="primary"/>

                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{StaticResource SuccessBrush}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
