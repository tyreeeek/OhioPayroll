<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OhioPayroll.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="OhioPayroll.App.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="32" Margin="0">

            <!-- Page Header -->
            <StackPanel Spacing="8">
                <TextBlock Classes="page-title">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}">
                            <Binding Path="CompanyName"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="Payroll Dashboard Overview" Classes="page-subtitle"/>
            </StackPanel>

            <!-- Refresh Button -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Content="Refresh Data"
                        Command="{Binding RefreshCommand}"
                        Classes="primary"/>
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{StaticResource PrimaryBrush}"/>
            </StackPanel>

            <!-- Stats Grid - 3 columns -->
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="20" RowSpacing="20">

                <!-- Active Employees -->
                <Border Grid.Column="0" Grid.Row="0" Classes="stat-card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="ACTIVE EMPLOYEES" Classes="stat-label"/>
                        <TextBlock Text="{Binding ActiveEmployeeCount}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

                <!-- YTD Gross Pay -->
                <Border Grid.Column="1" Grid.Row="0" Classes="stat-card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="YTD GROSS PAY" Classes="stat-label"/>
                        <TextBlock Text="{Binding YtdGrossPayDisplay}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

                <!-- YTD Net Pay -->
                <Border Grid.Column="2" Grid.Row="0" Classes="stat-card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="YTD NET PAY" Classes="stat-label"/>
                        <TextBlock Text="{Binding YtdNetPayDisplay}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

                <!-- Last Payroll Run -->
                <Border Grid.Column="0" Grid.Row="1" Classes="stat-card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="LAST PAYROLL RUN" Classes="stat-label"/>
                        <TextBlock Text="{Binding LastPayrollGrossDisplay}" Classes="stat-value"/>
                        <TextBlock Text="{Binding LastPayrollDateDisplay}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- YTD Total Taxes -->
                <Border Grid.Column="1" Grid.Row="1" Classes="stat-card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="YTD TOTAL TAXES" Classes="stat-label"/>
                        <TextBlock Text="{Binding YtdTotalTaxesDisplay}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

                <!-- Current Tax Year -->
                <Border Grid.Column="2" Grid.Row="1" Classes="stat-card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="CURRENT TAX YEAR" Classes="stat-label"/>
                        <TextBlock Text="{Binding CurrentTaxYear}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- Tax Table Alert -->
            <Border IsVisible="{Binding HasTaxTableAlert}"
                    Background="#FFF8E1"
                    CornerRadius="8"
                    Padding="24"
                    BorderBrush="#FFB300"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Alert" FontSize="16" FontWeight="600" Foreground="#E65100"/>
                    <TextBlock Text="{Binding TaxTableAlertMessage}"
                               FontSize="14"
                               Foreground="#BF360C"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Quarterly Breakdown Section -->
            <Border Classes="card">
                <StackPanel Spacing="24">

                    <TextBlock Text="Quarterly Breakdown" Classes="section-header"/>

                    <!-- Quarter Tabs -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Year-to-Date" Classes="secondary"
                                Command="{Binding SelectQuarterCommand}" CommandParameter="0"/>
                        <Button Content="Q1" Classes="secondary"
                                Command="{Binding SelectQuarterCommand}" CommandParameter="1"/>
                        <Button Content="Q2" Classes="secondary"
                                Command="{Binding SelectQuarterCommand}" CommandParameter="2"/>
                        <Button Content="Q3" Classes="secondary"
                                Command="{Binding SelectQuarterCommand}" CommandParameter="3"/>
                        <Button Content="Q4" Classes="secondary"
                                Command="{Binding SelectQuarterCommand}" CommandParameter="4"/>
                    </StackPanel>

                    <TextBlock Text="{Binding QuarterLabel}"
                               FontSize="15"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <!-- Quarter Stats Grid - 3 columns, 2 rows -->
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="16">

                        <Border Grid.Column="0" Grid.Row="0"
                                Background="{StaticResource SurfaceHoverBrush}"
                                CornerRadius="6" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="GROSS PAY" FontSize="11" FontWeight="600"
                                          Foreground="{StaticResource TextMutedBrush}" LetterSpacing="0.5"/>
                                <TextBlock Text="{Binding QuarterGrossPayDisplay}" FontSize="24" FontWeight="700"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Grid.Row="0"
                                Background="{StaticResource SurfaceHoverBrush}"
                                CornerRadius="6" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="NET PAY" FontSize="11" FontWeight="600"
                                          Foreground="{StaticResource TextMutedBrush}" LetterSpacing="0.5"/>
                                <TextBlock Text="{Binding QuarterNetPayDisplay}" FontSize="24" FontWeight="700"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Grid.Row="0"
                                Background="{StaticResource SurfaceHoverBrush}"
                                CornerRadius="6" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="FEDERAL TAX" FontSize="11" FontWeight="600"
                                          Foreground="{StaticResource TextMutedBrush}" LetterSpacing="0.5"/>
                                <TextBlock Text="{Binding QuarterFederalTaxDisplay}" FontSize="24" FontWeight="700"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="0" Grid.Row="1"
                                Background="{StaticResource SurfaceHoverBrush}"
                                CornerRadius="6" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="STATE TAX" FontSize="11" FontWeight="600"
                                          Foreground="{StaticResource TextMutedBrush}" LetterSpacing="0.5"/>
                                <TextBlock Text="{Binding QuarterStateTaxDisplay}" FontSize="24" FontWeight="700"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Grid.Row="1"
                                Background="{StaticResource SurfaceHoverBrush}"
                                CornerRadius="6" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="SOCIAL SECURITY" FontSize="11" FontWeight="600"
                                          Foreground="{StaticResource TextMutedBrush}" LetterSpacing="0.5"/>
                                <TextBlock Text="{Binding QuarterSsTaxDisplay}" FontSize="24" FontWeight="700"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Grid.Row="1"
                                Background="{StaticResource SurfaceHoverBrush}"
                                CornerRadius="6" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="MEDICARE" FontSize="11" FontWeight="600"
                                          Foreground="{StaticResource TextMutedBrush}" LetterSpacing="0.5"/>
                                <TextBlock Text="{Binding QuarterMedicareTaxDisplay}" FontSize="24" FontWeight="700"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                    </Grid>

                    <!-- Payroll Runs Count -->
                    <Border Background="{StaticResource SurfaceHoverBrush}"
                            CornerRadius="6" Padding="20" HorizontalAlignment="Left">
                        <StackPanel Spacing="8" Orientation="Horizontal">
                            <TextBlock Text="PAYROLL RUNS:" FontSize="13" FontWeight="600"
                                      Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding QuarterPayrollRunCount}" FontSize="20" FontWeight="700"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Tax Liability Status -->
                    <Border Background="{StaticResource SurfaceHoverBrush}"
                            CornerRadius="6" Padding="24"
                            IsVisible="{Binding QuarterIsSpecificQuarter}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Tax Liability Status" FontSize="16" FontWeight="600"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>

                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="32">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Owed" FontSize="12"
                                              Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding QuarterTaxOwedDisplay}" FontSize="20" FontWeight="600"
                                              Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Paid" FontSize="12"
                                              Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding QuarterTaxPaidDisplay}" FontSize="20" FontWeight="600"
                                              Foreground="{StaticResource SuccessBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Balance" FontSize="12"
                                              Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding QuarterTaxBalanceDisplay}" FontSize="20" FontWeight="600"
                                               IsVisible="{Binding QuarterHasBalance}"
                                               Foreground="{StaticResource DangerBrush}"/>
                                    <TextBlock Text="{Binding QuarterTaxBalanceDisplay}" FontSize="20" FontWeight="600"
                                               IsVisible="{Binding !QuarterHasBalance}"
                                               Foreground="{StaticResource SuccessBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Spacing="4">
                                    <TextBlock Text="941 Due Date" FontSize="12"
                                              Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding QuarterDueDateDisplay}" FontSize="20" FontWeight="600"
                                               IsVisible="{Binding QuarterIsOverdue}"
                                               Foreground="{StaticResource DangerBrush}"/>
                                    <TextBlock Text="{Binding QuarterDueDateDisplay}" FontSize="20" FontWeight="600"
                                               IsVisible="{Binding !QuarterIsOverdue}"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
