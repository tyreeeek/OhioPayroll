<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OhioPayroll.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
        x:Class="OhioPayroll.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Ohio Payroll"
        Icon="/Assets/ohio-payroll.ico"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <!-- Professional Navigation Items -->
        <Style Selector="Button.nav-item">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style Selector="Button.nav-item:pointerover">
            <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="Button.nav-active">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="600"/>
        </Style>

        <Style Selector="TextBlock.nav-section">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="700"/>
            <Setter Property="Margin" Value="16,20,0,8"/>
            <Setter Property="LetterSpacing" Value="0.8"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="240,*">
        <!-- Professional Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}">
            <DockPanel>
                <!-- App Branding -->
                <Border DockPanel.Dock="Top" Padding="20,32,20,24">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Ohio Payroll" FontSize="20" FontWeight="700"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   LetterSpacing="-0.5"/>
                        <TextBlock Text="Professional Edition" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontWeight="500"/>
                    </StackPanel>
                </Border>

                <!-- Theme Toggle -->
                <Border DockPanel.Dock="Bottom" Padding="16" BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource BorderBrush}">
                    <Button Classes="ghost" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="ToggleTheme">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="◐" FontSize="16"/>
                            <TextBlock Text="Toggle Theme" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Navigation Menu -->
                <ScrollViewer>
                    <StackPanel Name="NavPanel" Margin="12,8,12,16">
                        <Button Content="Dashboard" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"/>

                        <TextBlock Text="PAYROLL" Classes="nav-section"/>
                        <Button Content="Employees" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Employees"/>
                        <Button Content="Contractors" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Contractors"/>
                        <Button Content="Run Payroll" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Payroll"/>
                        <Button Content="Contractor Payroll" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="ContractorPayroll"/>

                        <TextBlock Text="PAYMENTS" Classes="nav-section"/>
                        <Button Content="Bank Accounts" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="BankAccounts"/>
                        <Button Content="Print Checks" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="CheckPrinting"/>
                        <Button Content="Direct Deposit" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="DirectDeposit"/>

                        <TextBlock Text="COMPLIANCE" Classes="nav-section"/>
                        <Button Content="Quarterly Reports" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Quarterly"/>
                        <Button Content="Tax Liability" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="TaxLiability"/>
                        <Button Content="Reports" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Reports"/>
                        <Button Content="Year-End / W-2 &amp; 1099" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="YearEnd"/>

                        <TextBlock Text="SYSTEM" Classes="nav-section"/>
                        <Button Content="Settings" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Settings"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}" Padding="40,32">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </Grid>

</Window>
