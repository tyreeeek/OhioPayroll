<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OhioPayroll.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
        x:Class="OhioPayroll.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Ohio Payroll"
        Icon="/Assets/ohio-payroll.ico"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Styles>
        <!-- Nav Item — Clean minimal -->
        <Style Selector="Button.nav-item">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="400"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
        <Style Selector="Button.nav-item:pointerover">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.nav-active">
            <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="FontWeight" Value="600"/>
        </Style>

        <!-- Section Labels -->
        <Style Selector="TextBlock.nav-section">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="700"/>
            <Setter Property="Margin" Value="14,18,0,6"/>
            <Setter Property="LetterSpacing" Value="1.2"/>
        </Style>

        <!-- Window chrome buttons -->
        <Style Selector="Button.chrome-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.chrome-btn:pointerover">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.close-btn:pointerover">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="36,*" ColumnDefinitions="240,*">

        <!-- ===== TITLE BAR (Row 0) ===== -->

        <!-- Left: logo area -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}"
                PointerPressed="TitleBar_PointerPressed">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0" Spacing="10">
                <Border Background="{StaticResource PrimaryBrush}" CornerRadius="6" Width="24" Height="24">
                    <TextBlock Text="O" FontSize="13" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Ohio Payroll" FontSize="13" FontWeight="600"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Right: drag + window controls -->
        <Border Grid.Row="0" Grid.Column="1"
                Background="{StaticResource BackgroundBrush}"
                PointerPressed="TitleBar_PointerPressed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Classes="chrome-btn" FontSize="14" Content="—" Click="MinimizeClick"/>
                <Button Classes="chrome-btn" FontSize="12" Content="□" Click="MaximizeClick"/>
                <Button Classes="chrome-btn close-btn" FontSize="13" Content="✕" Click="CloseClick"/>
            </StackPanel>
        </Border>

        <!-- ===== SIDEBAR (Row 1, Column 0) ===== -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}">
            <DockPanel>
                <!-- Bottom: Theme Toggle + Version -->
                <Border DockPanel.Dock="Bottom" Padding="14,12"
                        BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
                    <StackPanel Spacing="6">
                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0"
                                Padding="10,8" CornerRadius="6" Cursor="Hand"
                                Click="ToggleTheme">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="◐" FontSize="14" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="Toggle Theme" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="v2.7.0" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <ScrollViewer>
                    <StackPanel Name="NavPanel" Margin="10,6,10,12">

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Dashboard">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="⊞" FontSize="15" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Dashboard"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="PAYROLL" Classes="nav-section"/>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Employees">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="♦" FontSize="13" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Employees"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Contractors">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="◆" FontSize="13" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Contractors"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Payroll">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="$" FontSize="14" FontWeight="Bold" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Run Payroll"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="ContractorPayroll">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="¢" FontSize="14" FontWeight="Bold" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Contractor Payroll"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="PAYMENTS" Classes="nav-section"/>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="BankAccounts">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="▣" FontSize="14" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Bank Accounts"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="CheckPrinting">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="⎙" FontSize="15" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Print Checks"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="DirectDeposit">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="⇄" FontSize="15" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Direct Deposit"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="COMPLIANCE" Classes="nav-section"/>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Quarterly">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="▦" FontSize="14" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Quarterly Reports"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="TaxLiability">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="▤" FontSize="14" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Tax Liability"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Reports">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="☰" FontSize="15" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Reports"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="YearEnd">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="✦" FontSize="13" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Year-End / W-2 &amp; 1099"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="SYSTEM" Classes="nav-section"/>

                        <Button Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Settings">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="⚙" FontSize="15" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="Settings"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== MAIN CONTENT (Row 1, Column 1) ===== -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="{StaticResource BackgroundBrush}" Padding="36,28">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>

    </Grid>

</Window>
