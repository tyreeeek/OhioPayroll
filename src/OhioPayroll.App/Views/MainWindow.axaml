<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OhioPayroll.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
        x:Class="OhioPayroll.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Ohio Payroll"
        Icon="/Assets/ohio-payroll.ico"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Styles>
        <!-- Professional Navigation Items -->
        <Style Selector="Button.nav-item">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style Selector="Button.nav-item:pointerover">
            <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="Button.nav-active">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="600"/>
        </Style>

        <Style Selector="TextBlock.nav-section">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="700"/>
            <Setter Property="Margin" Value="16,20,0,8"/>
            <Setter Property="LetterSpacing" Value="0.8"/>
        </Style>

        <!-- Custom chrome button styles -->
        <Style Selector="Button.chrome-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.chrome-btn:pointerover">
            <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.close-btn:pointerover">
            <Setter Property="Background" Value="#E81123"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="40,*" ColumnDefinitions="220,*">

        <!-- ===== TITLE BAR (Row 0) ===== -->

        <!-- Left title bar: app name on sidebar background -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderThickness="0,0,1,1" BorderBrush="{StaticResource BorderBrush}"
                PointerPressed="TitleBar_PointerPressed">
            <TextBlock Text="Ohio Payroll" FontSize="14" FontWeight="700"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="20,0"/>
        </Border>

        <!-- Right title bar: draggable area + window control buttons -->
        <Border Grid.Row="0" Grid.Column="1"
                Background="{StaticResource BackgroundBrush}"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}"
                PointerPressed="TitleBar_PointerPressed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Classes="chrome-btn" FontSize="16" Content="—" Click="MinimizeClick"/>
                <Button Classes="chrome-btn" FontSize="13" Content="□" Click="MaximizeClick"/>
                <Button Classes="chrome-btn close-btn" FontSize="14" Content="✕" Click="CloseClick"/>
            </StackPanel>
        </Border>

        <!-- ===== SIDEBAR (Row 1, Column 0) ===== -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}">
            <DockPanel>
                <!-- Theme Toggle at bottom -->
                <Border DockPanel.Dock="Bottom" Padding="16" BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource BorderBrush}">
                    <Button Classes="ghost" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="ToggleTheme">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="◐" FontSize="16"/>
                            <TextBlock Text="Toggle Theme" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Navigation Menu -->
                <ScrollViewer>
                    <StackPanel Name="NavPanel" Margin="12,8,12,16">
                        <Button Content="Dashboard" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"/>

                        <TextBlock Text="PAYROLL" Classes="nav-section"/>
                        <Button Content="Employees" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Employees"/>
                        <Button Content="Contractors" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Contractors"/>
                        <Button Content="Run Payroll" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Payroll"/>
                        <Button Content="Contractor Payroll" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="ContractorPayroll"/>

                        <TextBlock Text="PAYMENTS" Classes="nav-section"/>
                        <Button Content="Bank Accounts" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="BankAccounts"/>
                        <Button Content="Print Checks" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="CheckPrinting"/>
                        <Button Content="Direct Deposit" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="DirectDeposit"/>

                        <TextBlock Text="COMPLIANCE" Classes="nav-section"/>
                        <Button Content="Quarterly Reports" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Quarterly"/>
                        <Button Content="Tax Liability" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="TaxLiability"/>
                        <Button Content="Reports" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Reports"/>
                        <Button Content="Year-End / W-2 &amp; 1099" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="YearEnd"/>

                        <TextBlock Text="SYSTEM" Classes="nav-section"/>
                        <Button Content="Settings" Classes="nav-item"
                                Command="{Binding NavigateToCommand}" CommandParameter="Settings"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== MAIN CONTENT (Row 1, Column 1) ===== -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="{StaticResource BackgroundBrush}" Padding="40,32">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>

    </Grid>

</Window>
