<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OhioPayroll.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             x:Class="OhioPayroll.App.Views.ContractorPayrollView"
             x:DataType="vm:ContractorPayrollViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="24,20" Margin="0,0,0,24">
            <StackPanel Spacing="12">
                <TextBlock Text="Contractor Payroll Processing"
                           FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="32">
                    <TextBlock Text="Step 1: Period" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                               Opacity="{Binding IsStep1, Converter={StaticResource BoolToOpacityConverter}}"/>
                    <TextBlock Text="→" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Step 2: Hours/Days" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                               Opacity="{Binding IsStep2, Converter={StaticResource BoolToOpacityConverter}}"/>
                    <TextBlock Text="→" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Step 3: Preview" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                               Opacity="{Binding IsStep3, Converter={StaticResource BoolToOpacityConverter}}"/>
                    <TextBlock Text="→" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Step 4: Complete" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                               Opacity="{Binding IsStep4, Converter={StaticResource BoolToOpacityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="24,0,24,24">
            <StackPanel Spacing="24">

                <!-- Step 1: Select Period -->
                <Border IsVisible="{Binding IsStep1}" Classes="card">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Select Pay Period" Classes="section-header"/>

                        <Grid ColumnDefinitions="*,24,*" RowDefinitions="Auto,Auto" RowSpacing="16">
                            <!-- Period Start -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                                <TextBlock Text="Period Start Date" Classes="label"/>
                                <CalendarDatePicker SelectedDate="{Binding PeriodStart}"
                                                   HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <!-- Period End -->
                            <StackPanel Grid.Column="2" Grid.Row="0" Spacing="4">
                                <TextBlock Text="Period End Date" Classes="label"/>
                                <CalendarDatePicker SelectedDate="{Binding PeriodEnd}"
                                                   HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <!-- Pay Date -->
                            <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                                <TextBlock Text="Pay Date" Classes="label"/>
                                <CalendarDatePicker SelectedDate="{Binding PayDate}"
                                                   HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <!-- Pay Frequency -->
                            <StackPanel Grid.Column="2" Grid.Row="1" Spacing="4">
                                <TextBlock Text="Pay Frequency" Classes="label"/>
                                <ComboBox ItemsSource="{Binding PayFrequencyValues}"
                                         SelectedItem="{Binding PayFrequency}"
                                         HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="This will create a new contractor payroll run for the selected period. Active contractors with hourly or daily rates will be loaded in the next step."
                                   FontSize="13" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Step 2: Enter Hours/Days -->
                <Border IsVisible="{Binding IsStep2}" Classes="card">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Enter Hours or Days Worked" Classes="section-header"/>
                        <TextBlock Text="Enter the hours or days worked for each contractor during this pay period. Leave blank to exclude a contractor from this payroll run."
                                   FontSize="13" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>

                        <DataGrid ItemsSource="{Binding PaymentEntries}"
                                 AutoGenerateColumns="False"
                                 IsReadOnly="False"
                                 CanUserReorderColumns="False"
                                 CanUserResizeColumns="True"
                                 GridLinesVisibility="Horizontal"
                                 HeadersVisibility="Column"
                                 MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Contractor"
                                                   Binding="{Binding ContractorName}"
                                                   Width="*"
                                                   IsReadOnly="True"/>
                                <DataGridTextColumn Header="Rate Type"
                                                   Binding="{Binding RateTypeDisplay}"
                                                   Width="110"
                                                   IsReadOnly="True"/>
                                <DataGridTextColumn Header="Rate"
                                                   Binding="{Binding RateDisplay}"
                                                   Width="110"
                                                   IsReadOnly="True"/>
                                <DataGridTextColumn Header="Hours/Days"
                                                   Binding="{Binding HoursOrDays, StringFormat=N2}"
                                                   Width="110"/>
                                <DataGridTemplateColumn Header="Payment Method" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding $parent[UserControl].((vm:ContractorPayrollViewModel)DataContext).PaymentMethodValues}"
                                                     SelectedItem="{Binding PaymentMethod}"
                                                     HorizontalAlignment="Stretch"
                                                     Margin="4,2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Amount"
                                                   Binding="{Binding CalculatedAmount, StringFormat=C2}"
                                                   Width="130"
                                                   IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="{Binding PaymentEntries.Count, StringFormat='Total Contractors: {0}'}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Step 3: Preview -->
                <Border IsVisible="{Binding IsStep3}" Classes="card">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Preview Payroll Run" Classes="section-header"/>

                        <!-- Summary Info -->
                        <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                            <TextBlock Grid.Column="0" Grid.Row="0" Text="Period:" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding PeriodStart, StringFormat='d'}" Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Grid.Column="0" Grid.Row="1" Text="To:" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding PeriodEnd, StringFormat='d'}" Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Grid.Column="0" Grid.Row="2" Text="Pay Date:" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Grid.Row="2" Text="{Binding PayDate, StringFormat='d'}" Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Grid.Column="0" Grid.Row="3" Text="Pay Frequency:" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Grid.Row="3" Text="{Binding PayFrequency}" Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Grid.Column="0" Grid.Row="4" Text="Total Amount:" FontWeight="Bold" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Grid.Row="4" Text="{Binding TotalAmount, StringFormat=C2}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,8"/>

                        <!-- Payment List -->
                        <TextBlock Text="Payments to Process:" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <DataGrid ItemsSource="{Binding PaymentEntries}"
                                 AutoGenerateColumns="False"
                                 IsReadOnly="True"
                                 GridLinesVisibility="Horizontal"
                                 HeadersVisibility="Column"
                                 MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Contractor" Binding="{Binding ContractorName}" Width="*"/>
                                <DataGridTextColumn Header="Rate Type" Binding="{Binding RateTypeDisplay}" Width="110"/>
                                <DataGridTextColumn Header="Rate" Binding="{Binding RateDisplay}" Width="110"/>
                                <DataGridTextColumn Header="Hours/Days" Binding="{Binding HoursOrDays, StringFormat=N2}" Width="110"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding CalculatedAmount, StringFormat=C2}" Width="130"/>
                                <DataGridTextColumn Header="Method" Binding="{Binding PaymentMethod}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Background="{StaticResource WarningBrush}" CornerRadius="6" Padding="16" Opacity="0.15">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Warning: Finalization is Permanent" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource WarningBrush}">
                                    Once finalized, this payroll run cannot be edited or deleted. Payment amounts will be locked and historical snapshots will be created.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 4: Complete -->
                <Border IsVisible="{Binding IsStep4}" Classes="card">
                    <StackPanel Spacing="20" HorizontalAlignment="Center">
                        <TextBlock Text="✓" FontSize="72" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Payroll Finalized Successfully!" Classes="page-title" HorizontalAlignment="Center" Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='Total Amount: {0:C2}'}"
                                   FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Payments are now locked. Click below to generate paystubs (includes checks for Check payment method)."
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <Button Content="Generate Paystubs &amp; Checks"
                                    Command="{Binding GeneratePaystubsCommand}"
                                    IsEnabled="{Binding !IsProcessing}"
                                    Padding="16,8"
                                    Classes="primary"/>
                        </StackPanel>

                        <Button Content="Return to Contractor List"
                                Command="{Binding CancelCommand}"
                                HorizontalAlignment="Center"
                                Classes="secondary"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <Border IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
                        Background="{StaticResource DangerBrush}" CornerRadius="6" Padding="16" Opacity="0.15">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Navigation Buttons -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,16" Background="{StaticResource BackgroundBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <Button Grid.Column="0"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsVisible="{Binding !IsStep4}"
                        Classes="secondary"/>

                <Button Grid.Column="2"
                        Content="← Previous"
                        Command="{Binding PreviousStepCommand}"
                        IsEnabled="{Binding CanGoBack}"
                        IsVisible="{Binding !IsStep4}"
                        Margin="0,0,12,0"
                        Classes="secondary"/>

                <Button Grid.Column="3"
                        Content="Next →"
                        Command="{Binding NextStepCommand}"
                        IsEnabled="{Binding CanGoNext}"
                        IsVisible="{Binding !IsStep3}"
                        Classes="primary"/>

                <Button Grid.Column="3"
                        Content="Finalize Payroll"
                        Command="{Binding FinalizePayrollCommand}"
                        IsEnabled="{Binding !IsProcessing}"
                        IsVisible="{Binding IsStep3}"
                        Classes="primary"/>
            </Grid>
        </Border>
    </Grid>

</UserControl>
