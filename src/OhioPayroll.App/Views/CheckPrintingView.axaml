<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OhioPayroll.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="OhioPayroll.App.Views.CheckPrintingView"
             x:DataType="vm:CheckPrintingViewModel">

    <ScrollViewer>
        <StackPanel Spacing="24">

            <!-- Page Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="page-title"/>
                <TextBlock Text="{Binding Subtitle}" Classes="page-subtitle"/>
            </StackPanel>

            <!-- Payroll Run Selection -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Select Payroll Run" Classes="section-header"/>
                    <ComboBox ItemsSource="{Binding PayrollRunRows}"
                              SelectedItem="{Binding SelectedRun}"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Choose a finalized payroll run..."
                              MaxDropDownHeight="300">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PayrollRunRow">
                                <TextBlock Text="{Binding Display}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Paychecks Grid -->
            <Border Classes="card">
                <DockPanel>
                    <TextBlock Text="Paychecks"
                               Classes="section-header"
                               DockPanel.Dock="Top"
                               Margin="0,0,0,12"/>

                    <DataGrid ItemsSource="{Binding PaycheckRows}"
                              SelectedItem="{Binding SelectedPaycheckRow}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              MinHeight="150"
                              MaxHeight="400">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Employee"
                                                Binding="{Binding EmployeeName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Check #"
                                                Binding="{Binding CheckNumber}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Gross Pay"
                                                Binding="{Binding GrossPay, StringFormat='{}{0:C}'}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Net Pay"
                                                Binding="{Binding NetPay, StringFormat='{}{0:C}'}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Action Buttons -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Actions" Classes="section-header"/>

                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Print All Checks"
                                Command="{Binding PrintChecksCommand}"
                                Classes="primary"
                                Margin="0,0,12,8"/>
                        <Button Content="Print All Paystubs"
                                Command="{Binding PrintPaystubsCommand}"
                                Classes="primary"
                                Margin="0,0,12,8"/>
                        <Button Content="Print Calibration Page"
                                Command="{Binding PrintCalibrationCommand}"
                                Classes="secondary"
                                Margin="0,0,12,8"/>

                        <Border Width="1" Background="{StaticResource BorderBrush}" Margin="4,0,12,8" Height="30"
                                VerticalAlignment="Center"/>

                        <Button Content="Void Selected Check"
                                Command="{Binding VoidPaycheckCommand}"
                                IsEnabled="{Binding CanVoidSelectedPaycheck}"
                                Classes="danger"
                                Margin="0,0,12,8"/>
                    </WrapPanel>

                    <!-- Busy indicator -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                IsVisible="{Binding IsBusy}">
                        <ProgressBar IsIndeterminate="True"
                                     Width="120"
                                     Height="4"/>
                        <TextBlock Text="Generating..."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status Message - Error -->
            <Border IsVisible="{Binding IsStatusError}"
                    Background="#FFEBEE" BorderBrush="#EF5350" BorderThickness="1"
                    CornerRadius="6" Padding="16,12">
                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#C62828"/>
            </Border>

            <!-- Status Message - Success -->
            <Border IsVisible="{Binding !IsStatusError}"
                    Margin="0">
                <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="#E8F5E9" BorderBrush="#66BB6A" BorderThickness="1"
                        CornerRadius="6" Padding="16,12">
                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2E7D32"/>
                </Border>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
