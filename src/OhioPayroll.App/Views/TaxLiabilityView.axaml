<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OhioPayroll.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="OhioPayroll.App.Views.TaxLiabilityView"
             x:DataType="vm:TaxLiabilityViewModel">

    <Panel>
        <!-- Main Content -->
        <DockPanel IsVisible="{Binding !IsPaymentDialogOpen}">

            <!-- Page Header -->
            <Border DockPanel.Dock="Top" Padding="0,0,0,24">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Title}" Classes="page-title"/>
                    <TextBlock Text="{Binding Subtitle}" Classes="page-subtitle"/>
                </StackPanel>
            </Border>

            <!-- Summary Cards -->
            <Border DockPanel.Dock="Top" Padding="0,0,0,24">
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">

                    <Border Grid.Column="0" Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Text="TOTAL OWED" Classes="stat-label"/>
                            <TextBlock Text="{Binding TotalOwedDisplay}" FontSize="28" FontWeight="700"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Text="TOTAL PAID" Classes="stat-label"/>
                            <TextBlock Text="{Binding TotalPaidDisplay}" FontSize="28" FontWeight="700"
                                       Foreground="{StaticResource SuccessBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Classes="stat-card">
                        <StackPanel Spacing="8">
                            <TextBlock Text="BALANCE DUE" Classes="stat-label"/>
                            <TextBlock Text="{Binding BalanceDueDisplay}" FontSize="28" FontWeight="700"
                                       Foreground="{StaticResource DangerBrush}"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- Filter Row -->
            <Border DockPanel.Dock="Top" Padding="0,0,0,16">
                <StackPanel Orientation="Horizontal" Spacing="16">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Year" Classes="label"/>
                        <ComboBox ItemsSource="{Binding YearOptions}"
                                  SelectedItem="{Binding FilterYear}"
                                  MinWidth="100"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Quarter" Classes="label"/>
                        <ComboBox ItemsSource="{Binding QuarterOptions}"
                                  SelectedItem="{Binding FilterQuarter}"
                                  MinWidth="100"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Status" Classes="label"/>
                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding FilterStatus}"
                                  MinWidth="120"/>
                    </StackPanel>

                    <Button Content="Refresh"
                            Command="{Binding LoadLiabilitiesCommand}"
                            VerticalAlignment="Bottom"
                            Padding="16,8"
                            Classes="secondary"/>

                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <Border DockPanel.Dock="Top" Padding="0,0,0,16">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Mark as Paid"
                            Command="{Binding MarkAsPaidCommand}"
                            Padding="16,8"
                            Classes="primary"/>
                    <Button Content="Record Partial Payment"
                            Command="{Binding RecordPartialPaymentCommand}"
                            Padding="16,8"
                            Classes="secondary"/>
                </StackPanel>
            </Border>

            <!-- DataGrid -->
            <DataGrid ItemsSource="{Binding Liabilities}"
                      SelectedItem="{Binding SelectedLiability}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tax Type"
                                        Binding="{Binding TaxTypeDisplay}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Year"
                                        Binding="{Binding TaxYear}"
                                        Width="70"/>
                    <DataGridTextColumn Header="Qtr"
                                        Binding="{Binding QuarterDisplay}"
                                        Width="55"/>
                    <DataGridTextColumn Header="Period"
                                        Binding="{Binding PeriodDisplay}"
                                        Width="200"/>
                    <DataGridTextColumn Header="Amount Owed"
                                        Binding="{Binding AmountOwed, StringFormat=\{0:C\}}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Amount Paid"
                                        Binding="{Binding AmountPaid, StringFormat=\{0:C\}}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Balance"
                                        Binding="{Binding Balance, StringFormat=\{0:C\}}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding StatusDisplay}"
                                        Width="80"/>
                    <DataGridTextColumn Header="Payment Date"
                                        Binding="{Binding PaymentDateDisplay}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Reference"
                                        Binding="{Binding PaymentReference}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>

        <!-- Payment Dialog Overlay -->
        <Border IsVisible="{Binding IsPaymentDialogOpen}"
                Background="#80000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="24"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    MaxWidth="450"
                    MaxHeight="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 4 16 #40000000">
                <StackPanel Spacing="16">

                    <TextBlock Text="{Binding PaymentDialogTitle}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <!-- Validation Error -->
                    <Border IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Background="#FFEBEE"
                            BorderBrush="#EF5350"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8">
                        <TextBlock Text="{Binding ValidationError}"
                                   Foreground="#C62828"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Payment Amount ($)" Classes="label"/>
                        <NumericUpDown Value="{Binding PaymentAmount}"
                                       Minimum="0"
                                       FormatString="F2"
                                       Increment="100"
                                       IsReadOnly="{Binding !IsPartialPayment}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Payment Reference (check #, EFT confirmation, etc.)" Classes="label"/>
                        <TextBox Text="{Binding PaymentReference}"
                                 Watermark="Enter reference number"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                HorizontalAlignment="Right"
                                Margin="0,8,0,0">
                        <Button Content="Cancel"
                                Command="{Binding CancelPaymentCommand}"
                                Padding="24,8"
                                Classes="secondary"/>
                        <Button Content="Confirm Payment"
                                Command="{Binding ConfirmPaymentCommand}"
                                Padding="24,8"
                                Classes="primary"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Border>
    </Panel>

</UserControl>
