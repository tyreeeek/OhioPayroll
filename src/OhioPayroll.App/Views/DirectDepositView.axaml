<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OhioPayroll.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="OhioPayroll.App.Views.DirectDepositView"
             x:DataType="vm:DirectDepositViewModel">

    <ScrollViewer>
        <StackPanel Spacing="24">

            <!-- Page Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="page-title"/>
                <TextBlock Text="{Binding Subtitle}" Classes="page-subtitle"/>
            </StackPanel>

            <!-- Payroll Run Selection -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Select Payroll Run" Classes="section-header"/>
                    <ComboBox ItemsSource="{Binding PayrollRunRows}"
                              SelectedItem="{Binding SelectedRun}"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Choose a finalized payroll run..."
                              MaxDropDownHeight="300">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PayrollRunRow">
                                <TextBlock Text="{Binding Display}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Summary Info Cards -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Summary" Classes="section-header"/>
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                        <!-- DD Employee Count -->
                        <Border Grid.Column="0" Classes="stat-card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="EMPLOYEES WITH DD" Classes="stat-label"/>
                                <TextBlock Text="{Binding DdEmployeeCount}" Classes="stat-value"
                                           Foreground="{StaticResource SuccessBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Amount -->
                        <Border Grid.Column="1" Classes="stat-card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="TOTAL DD AMOUNT" Classes="stat-label"/>
                                <TextBlock Text="{Binding DdTotalAmount, StringFormat='{}{0:C}'}" Classes="stat-value"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Missing DD Count -->
                        <Border Grid.Column="2" Classes="stat-card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="MISSING DD SETUP" Classes="stat-label"/>
                                <TextBlock Text="{Binding MissingDdCount}" Classes="stat-value"
                                           Foreground="{StaticResource DangerBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Warning for missing DD -->
                    <Border CornerRadius="6"
                            Padding="16,12"
                            Background="#FFF8E1"
                            BorderBrush="#FFB300"
                            BorderThickness="1"
                            IsVisible="{Binding MissingDdWarning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding MissingDdWarning}"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#E65100"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ACH Preview Grid -->
            <Border Classes="card">
                <DockPanel>
                    <TextBlock Text="ACH Entries Preview"
                               Classes="section-header"
                               DockPanel.Dock="Top"
                               Margin="0,0,0,12"/>

                    <DataGrid ItemsSource="{Binding AchPreviewRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              MinHeight="150"
                              MaxHeight="400">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Employee"
                                                Binding="{Binding EmployeeName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Routing #"
                                                Binding="{Binding RoutingLast4}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Account #"
                                                Binding="{Binding AccountLast4}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Type"
                                                Binding="{Binding AccountType}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Amount"
                                                Binding="{Binding Amount, StringFormat='{}{0:C}'}"
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Action Button -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Generate" Classes="section-header"/>

                    <Button Content="Generate ACH File"
                            Command="{Binding GenerateAchFileCommand}"
                            Padding="16,8"
                            FontSize="13"
                            MinWidth="180"
                            Classes="primary"/>

                    <!-- Busy indicator -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                IsVisible="{Binding IsBusy}">
                        <ProgressBar IsIndeterminate="True"
                                     Width="120"
                                     Height="4"/>
                        <TextBlock Text="Generating ACH file..."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status Message - Error -->
            <Border IsVisible="{Binding IsStatusError}"
                    Background="#FFEBEE" BorderBrush="#EF5350" BorderThickness="1"
                    CornerRadius="6" Padding="16,12">
                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#C62828"/>
            </Border>

            <!-- Status Message - Success -->
            <Border IsVisible="{Binding !IsStatusError}"
                    Margin="0">
                <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="#E8F5E9" BorderBrush="#66BB6A" BorderThickness="1"
                        CornerRadius="6" Padding="16,12">
                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2E7D32"/>
                </Border>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
