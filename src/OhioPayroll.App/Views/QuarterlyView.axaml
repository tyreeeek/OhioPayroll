<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OhioPayroll.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="900"
             x:Class="OhioPayroll.App.Views.QuarterlyView"
             x:DataType="vm:QuarterlyViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24">

            <!-- Header with Year / Quarter selectors -->
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Spacing="4">
                    <TextBlock Text="Quarterly Overview" Classes="page-title"/>
                    <TextBlock Text="Detailed payroll and tax breakdown by quarter."
                               Classes="page-subtitle"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Year" Classes="label"/>
                        <ComboBox ItemsSource="{Binding YearOptions}"
                                  SelectedItem="{Binding SelectedYear}"
                                  MinWidth="100"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Quarter" Classes="label"/>
                        <ComboBox ItemsSource="{Binding QuarterOptions}"
                                  SelectedItem="{Binding SelectedQuarter}"
                                  MinWidth="80"/>
                    </StackPanel>
                    <Button Content="Refresh"
                            Command="{Binding LoadDataCommand}"
                            VerticalAlignment="Bottom"
                            Padding="16,8"
                            Classes="secondary"/>
                </StackPanel>
            </DockPanel>

            <!-- Quarter Title and Period -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding QuarterTitle}" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="{Binding PeriodDisplay}" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                       Foreground="{StaticResource PrimaryBrush}"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Summary Cards Grid -->
            <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="16">

                <Border Grid.Column="0" Grid.Row="0" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="GROSS PAY" Classes="stat-label"/>
                        <TextBlock Text="{Binding GrossPayDisplay}" FontSize="22" FontWeight="700"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Grid.Row="0" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="NET PAY" Classes="stat-label"/>
                        <TextBlock Text="{Binding NetPayDisplay}" FontSize="22" FontWeight="700"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Grid.Row="0" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="FEDERAL TAX" Classes="stat-label"/>
                        <TextBlock Text="{Binding FederalTaxDisplay}" FontSize="22" FontWeight="700"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Grid.Row="0" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="STATE TAX (OH)" Classes="stat-label"/>
                        <TextBlock Text="{Binding StateTaxDisplay}" FontSize="22" FontWeight="700"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="0" Grid.Row="1" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="LOCAL TAX" Classes="stat-label"/>
                        <TextBlock Text="{Binding LocalTaxDisplay}" FontSize="22" FontWeight="700"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Grid.Row="1" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="SOCIAL SECURITY" Classes="stat-label"/>
                        <TextBlock Text="{Binding SsTaxDisplay}" FontSize="22" FontWeight="700"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Grid.Row="1" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="MEDICARE" Classes="stat-label"/>
                        <TextBlock Text="{Binding MedicareTaxDisplay}" FontSize="22" FontWeight="700"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Grid.Row="1" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="EMPLOYER TAXES" Classes="stat-label"/>
                        <TextBlock Text="{Binding EmployerTaxDisplay}" FontSize="22" FontWeight="700"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- 941 Status Banner -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Form 941 Status" FontSize="16" FontWeight="600"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="24">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="PAYROLL RUNS" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" FontWeight="600"/>
                            <TextBlock Text="{Binding PayrollRunCount}" FontSize="20" FontWeight="700"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="EMPLOYEES" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" FontWeight="600"/>
                            <TextBlock Text="{Binding EmployeeCount}" FontSize="20" FontWeight="700"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="DUE DATE" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" FontWeight="600"/>
                            <TextBlock Text="{Binding Form941DueDateDisplay}" FontSize="20" FontWeight="700"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       IsVisible="{Binding !IsOverdue}"/>
                            <TextBlock Text="{Binding Form941DueDateDisplay}" FontSize="20" FontWeight="700"
                                       Foreground="{StaticResource DangerBrush}"
                                       IsVisible="{Binding IsOverdue}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="4">
                            <TextBlock Text="STATUS" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" FontWeight="600"/>
                            <TextBlock Text="{Binding Form941StatusDisplay}" FontSize="20" FontWeight="700"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Overdue warning banner -->
            <Border IsVisible="{Binding IsOverdue}"
                    Background="#FFF8E1"
                    CornerRadius="8"
                    Padding="16,12"
                    BorderBrush="#FFB300"
                    BorderThickness="1">
                <TextBlock Text="This quarter has outstanding tax liabilities past the 941 due date. Please review and submit payments."
                           FontSize="14" Foreground="#E65100" FontWeight="SemiBold" TextWrapping="Wrap"/>
            </Border>

            <!-- Tax Liability by Type -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <DockPanel>
                        <TextBlock Text="Tax Liability by Type" FontSize="16" FontWeight="600"
                                   Foreground="{StaticResource TextPrimaryBrush}" DockPanel.Dock="Left"/>
                        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="24">
                            <StackPanel>
                                <TextBlock Text="TOTAL OWED" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" FontWeight="600"/>
                                <TextBlock Text="{Binding TotalOwedDisplay}" FontSize="16" FontWeight="700"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="TOTAL PAID" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" FontWeight="600"/>
                                <TextBlock Text="{Binding TotalPaidDisplay}" FontSize="16" FontWeight="700"
                                           Foreground="{StaticResource SuccessBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="BALANCE DUE" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" FontWeight="600"/>
                                <TextBlock Text="{Binding BalanceDueDisplay}" FontSize="16" FontWeight="700"
                                           Foreground="{StaticResource DangerBrush}"
                                           IsVisible="{Binding HasBalance}"/>
                                <TextBlock Text="{Binding BalanceDueDisplay}" FontSize="16" FontWeight="700"
                                           Foreground="{StaticResource SuccessBrush}"
                                           IsVisible="{Binding !HasBalance}"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid ItemsSource="{Binding TaxSummary}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              MinHeight="120">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tax Type"
                                                Binding="{Binding TaxTypeDisplay}"
                                                Width="160"/>
                            <DataGridTextColumn Header="Amount Owed"
                                                Binding="{Binding AmountOwedDisplay}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Amount Paid"
                                                Binding="{Binding AmountPaidDisplay}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Balance"
                                                Binding="{Binding BalanceDisplay}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Payroll Runs for Quarter -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Payroll Runs" FontSize="16" FontWeight="600"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <DataGrid ItemsSource="{Binding PayrollRuns}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              MinHeight="120">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pay Date"
                                                Binding="{Binding PayDateDisplay}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Period"
                                                Binding="{Binding PeriodDisplay}"
                                                Width="180"/>
                            <DataGridTextColumn Header="Employees"
                                                Binding="{Binding EmployeeCount}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Gross Pay"
                                                Binding="{Binding GrossPayDisplay}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Net Pay"
                                                Binding="{Binding NetPayDisplay}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Total Taxes"
                                                Binding="{Binding TotalTaxesDisplay}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
