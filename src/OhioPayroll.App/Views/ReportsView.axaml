<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OhioPayroll.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="OhioPayroll.App.Views.ReportsView"
             x:DataType="vm:ReportsViewModel">

    <UserControl.Styles>
        <Style Selector="Border.summary-card">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="MinHeight" Value="90"/>
        </Style>
        <Style Selector="TextBlock.card-header">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="TextBlock.card-value">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ListBox.report-list">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style Selector="ListBox.report-list ListBoxItem">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#CCC"/>
        </Style>
        <Style Selector="ListBox.report-list ListBoxItem:selected">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ListBox.report-list ListBoxItem:pointerover">
            <Setter Property="Background" Value="#383838"/>
        </Style>
        <Style Selector="Border.param-section">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <!-- Page Header -->
        <Border DockPanel.Dock="Top" Padding="8,8,8,0">
            <StackPanel Spacing="4">
                <TextBlock Text="Reports" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Generate payroll, tax, and compliance reports."
                           FontSize="14" Foreground="#888"/>
            </StackPanel>
        </Border>

        <!-- Main Content: Left Panel (Report Types) + Right Panel (Parameters) -->
        <Grid Margin="8,16,8,8" ColumnDefinitions="260,*">

            <!-- Left Panel: Report Type List -->
            <Border Grid.Column="0" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="REPORT TYPE"
                               FontSize="12" Foreground="#999" FontWeight="SemiBold"
                               Margin="4,0,0,8"/>
                    <ListBox Classes="report-list"
                             ItemsSource="{Binding ReportTypes}"
                             SelectedItem="{Binding SelectedReportType}"/>
                </DockPanel>
            </Border>

            <!-- Right Panel: Parameters and Actions -->
            <DockPanel Grid.Column="1">

                <!-- Status Message at Bottom -->
                <Border DockPanel.Dock="Bottom" Margin="0,12,0,0"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Border Background="#2D2D30" CornerRadius="6" Padding="16,12"
                            BorderBrush="#444" BorderThickness="1">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="13" Foreground="#4ADE80"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Border>

                <!-- Parameter Section -->
                <Border Classes="param-section">
                    <StackPanel Spacing="20">

                        <!-- Report Title -->
                        <TextBlock Text="{Binding SelectedReportType}"
                                   FontSize="20" FontWeight="Bold" Foreground="White"/>

                        <!-- Date Range Parameters -->
                        <StackPanel Spacing="12"
                                    IsVisible="{Binding ShowDateRange}">
                            <TextBlock Text="DATE RANGE" FontSize="12" Foreground="#999"
                                       FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Start Date" FontSize="12" Foreground="Gray"/>
                                    <DatePicker SelectedDate="{Binding StartDate}"
                                                MinWidth="180"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="End Date" FontSize="12" Foreground="Gray"/>
                                    <DatePicker SelectedDate="{Binding EndDate}"
                                                MinWidth="180"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Year Filter -->
                        <StackPanel Spacing="12"
                                    IsVisible="{Binding ShowYearFilter}">
                            <TextBlock Text="YEAR" FontSize="12" Foreground="#999"
                                       FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding AvailableYears}"
                                      SelectedItem="{Binding SelectedYear}"
                                      MinWidth="140"/>
                        </StackPanel>

                        <!-- Quarter Filter -->
                        <StackPanel Spacing="12"
                                    IsVisible="{Binding ShowQuarterFilter}">
                            <TextBlock Text="QUARTER" FontSize="12" Foreground="#999"
                                       FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding AvailableQuarters}"
                                      SelectedItem="{Binding SelectedQuarter}"
                                      MinWidth="140"/>
                        </StackPanel>

                        <!-- Generate Button -->
                        <Button Content="Generate Report"
                                Command="{Binding GenerateReportCommand}"
                                IsEnabled="{Binding !IsGenerating}"
                                Padding="24,10"
                                FontSize="14"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Left"
                                Classes="accent"/>

                        <!-- Generating indicator -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding IsGenerating}">
                            <TextBlock Text="Generating report, please wait..."
                                       FontSize="13" Foreground="#999"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>

