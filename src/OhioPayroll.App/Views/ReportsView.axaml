<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OhioPayroll.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="OhioPayroll.App.Views.ReportsView"
             x:DataType="vm:ReportsViewModel">


    <DockPanel>
        <!-- Page Header -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,32">
            <StackPanel Spacing="4">
                <TextBlock Text="Reports" Classes="page-title"/>
                <TextBlock Text="Generate payroll, tax, and compliance reports."
                           Classes="page-subtitle"/>
            </StackPanel>
        </Border>

        <!-- Main Content: Left Panel (Report Types) + Right Panel (Parameters) -->
        <Grid Margin="0,0,0,24" ColumnDefinitions="280,*">

            <!-- Left Panel: Report Type List -->
            <Border Grid.Column="0" Margin="0,0,24,0" Classes="card">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="REPORT TYPE"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <ListBox Background="{StaticResource SurfaceBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             CornerRadius="6"
                             Padding="4"
                             ItemsSource="{Binding ReportTypes}"
                             SelectedItem="{Binding SelectedReportType}"/>
                </DockPanel>
            </Border>

            <!-- Right Panel: Parameters and Actions -->
            <DockPanel Grid.Column="1">

                <!-- Status Message at Bottom -->
                <Border DockPanel.Dock="Bottom" Margin="0,16,0,0"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Border Background="#E8F5E9" BorderBrush="#66BB6A" BorderThickness="1"
                            CornerRadius="6" Padding="16,12">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="14" Foreground="#2E7D32" FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Border>

                <!-- Parameter Section -->
                <Border Classes="card">
                    <StackPanel Spacing="24">

                        <!-- Report Title -->
                        <TextBlock Text="{Binding SelectedReportType}"
                                   Classes="section-header"/>

                        <!-- Date Range Parameters -->
                        <StackPanel Spacing="12"
                                    IsVisible="{Binding ShowDateRange}">
                            <TextBlock Text="DATE RANGE" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Start Date" Classes="label"/>
                                    <DatePicker SelectedDate="{Binding StartDate}"
                                                MinWidth="200"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="End Date" Classes="label"/>
                                    <DatePicker SelectedDate="{Binding EndDate}"
                                                MinWidth="200"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Year Filter -->
                        <StackPanel Spacing="12"
                                    IsVisible="{Binding ShowYearFilter}">
                            <TextBlock Text="YEAR" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding AvailableYears}"
                                      SelectedItem="{Binding SelectedYear}"
                                      MinWidth="180"/>
                        </StackPanel>

                        <!-- Quarter Filter -->
                        <StackPanel Spacing="12"
                                    IsVisible="{Binding ShowQuarterFilter}">
                            <TextBlock Text="QUARTER" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding AvailableQuarters}"
                                      SelectedItem="{Binding SelectedQuarter}"
                                      MinWidth="180"/>
                        </StackPanel>

                        <!-- Generate Button -->
                        <Button Content="Generate Report"
                                Command="{Binding GenerateReportCommand}"
                                IsEnabled="{Binding !IsGenerating}"
                                Padding="24,10"
                                HorizontalAlignment="Left"
                                Classes="primary"/>

                        <!-- Generating indicator -->
                        <StackPanel Orientation="Horizontal" Spacing="12"
                                    IsVisible="{Binding IsGenerating}">
                            <TextBlock Text="Generating report, please wait..."
                                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
