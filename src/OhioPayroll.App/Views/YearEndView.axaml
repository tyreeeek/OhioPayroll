<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OhioPayroll.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="OhioPayroll.App.Views.YearEndView"
             x:DataType="vm:YearEndViewModel">


    <DockPanel>

        <!-- Page Header -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,24">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Title}" Classes="page-title"/>
                <TextBlock Text="{Binding Subtitle}" Classes="page-subtitle"/>
            </StackPanel>
        </Border>

        <!-- Summary Cards -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,24">
            <Grid ColumnDefinitions="*,*,*,*,*,*" RowDefinitions="Auto" ColumnSpacing="24">

                <Border Grid.Column="0" Classes="stat-card">
                    <StackPanel>
                        <TextBlock Text="EMPLOYEES" Classes="stat-label"/>
                        <TextBlock Text="{Binding EmployeeCountDisplay}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="stat-card">
                    <StackPanel>
                        <TextBlock Text="TOTAL WAGES" Classes="stat-label"/>
                        <TextBlock Text="{Binding TotalWagesDisplay}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="stat-card">
                    <StackPanel>
                        <TextBlock Text="FEDERAL TAX" Classes="stat-label"/>
                        <TextBlock Text="{Binding TotalFederalTaxDisplay}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Classes="stat-card">
                    <StackPanel>
                        <TextBlock Text="SS TAX" Classes="stat-label"/>
                        <TextBlock Text="{Binding TotalSsTaxDisplay}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Classes="stat-card">
                    <StackPanel>
                        <TextBlock Text="MEDICARE TAX" Classes="stat-label"/>
                        <TextBlock Text="{Binding TotalMedicareTaxDisplay}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="5" Classes="stat-card">
                    <StackPanel>
                        <TextBlock Text="STATE TAX" Classes="stat-label"/>
                        <TextBlock Text="{Binding TotalStateTaxDisplay}" Classes="stat-value"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- Year Selector and Generate All -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,24">
            <StackPanel Orientation="Horizontal" Spacing="20">

                <StackPanel Spacing="4">
                    <TextBlock Text="Tax Year" Classes="label"/>
                    <ComboBox ItemsSource="{Binding AvailableYears}"
                              SelectedItem="{Binding SelectedYear}"
                              MinWidth="140"/>
                </StackPanel>

                <Button Content="Generate All (W-2s, W-3, 1099-NECs, 1096, 940)"
                        Command="{Binding GenerateAllCommand}"
                        IsEnabled="{Binding !IsGenerating}"
                        VerticalAlignment="Bottom"
                        Padding="20,10"
                        Classes="primary"/>

            </StackPanel>
        </Border>

        <!-- Status Message -->
        <Border DockPanel.Dock="Bottom" Padding="0,16,0,0"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <Border Background="#E8F5E9" BorderBrush="#66BB6A" BorderThickness="1"
                    CornerRadius="6" Padding="16,12">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14" Foreground="#2E7D32" FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
            </Border>
        </Border>

        <!-- Generating indicator -->
        <Border DockPanel.Dock="Bottom" Padding="0,0,0,8"
                IsVisible="{Binding IsGenerating}">
            <TextBlock Text="Generating documents, please wait..."
                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>

        <!-- Main Scrollable Content -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="32" Margin="0,0,0,24">

                <!-- W-2 Employee Section -->
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <TextBlock Text="W-2 Employees" Classes="section-header"/>
                        <TextBlock Text="Employees with finalized payroll for the selected tax year" FontSize="13" Foreground="{StaticResource TextMutedBrush}"/>

                        <DataGrid ItemsSource="{Binding EmployeeRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  SelectionMode="Single"
                                  MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Employee"
                                                    Binding="{Binding EmployeeName}"
                                                    Width="200"/>
                                <DataGridTextColumn Header="SSN Last 4"
                                                    Binding="{Binding SsnLast4}"
                                                    Width="90"/>
                                <DataGridTextColumn Header="Total Wages"
                                                    Binding="{Binding TotalWagesDisplay}"
                                                    Width="130"/>
                                <DataGridTextColumn Header="Federal Tax"
                                                    Binding="{Binding FederalTaxDisplay}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="State Tax"
                                                    Binding="{Binding StateTaxDisplay}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="SS Tax"
                                                    Binding="{Binding SsTaxDisplay}"
                                                    Width="110"/>
                                <DataGridTextColumn Header="Medicare Tax"
                                                    Binding="{Binding MedicareTaxDisplay}"
                                                    Width="110"/>
                                <DataGridTextColumn Header="Local Tax"
                                                    Binding="{Binding LocalTaxDisplay}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- W-2 Generation Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                            <Button Content="Generate All W-2s"
                                    Command="{Binding GenerateOfficialW2sCommand}"
                                    IsEnabled="{Binding !IsGenerating}"
                                    Padding="16,8"
                                    Classes="primary"/>
                            <Button Content="Generate W-3"
                                    Command="{Binding GenerateW3Command}"
                                    IsEnabled="{Binding !IsGenerating}"
                                    Padding="16,8"
                                    Classes="secondary"/>
                            <Button Content="Export W-2 EFW2 File"
                                    Command="{Binding ExportEfw2Command}"
                                    IsEnabled="{Binding !IsGenerating}"
                                    Padding="16,8"
                                    Classes="secondary"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 1099 Contractor Section -->
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <TextBlock Text="1099-NEC Contractors" Classes="section-header"/>
                        <TextBlock Text="Contractors paid $600 or more receive a 1099-NEC" FontSize="13" Foreground="{StaticResource TextMutedBrush}"/>

                        <!-- Contractor Summary Cards -->
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="24" Margin="0,8,0,0">
                            <Border Grid.Column="0" Classes="stat-card">
                                <StackPanel>
                                    <TextBlock Text="CONTRACTORS" Classes="stat-label"/>
                                    <TextBlock Text="{Binding ContractorCountDisplay}" Classes="stat-value"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Classes="stat-card">
                                <StackPanel>
                                    <TextBlock Text="TOTAL PAYMENTS" Classes="stat-label"/>
                                    <TextBlock Text="{Binding TotalContractorPaymentsDisplay}" Classes="stat-value"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Classes="stat-card">
                                <StackPanel>
                                    <TextBlock Text="1099s REQUIRED" Classes="stat-label"/>
                                    <TextBlock Text="{Binding Form1099CountDisplay}" Classes="stat-value"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Contractor DataGrid -->
                        <DataGrid ItemsSource="{Binding ContractorRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  SelectionMode="Single"
                                  MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Contractor"
                                                    Binding="{Binding ContractorName}"
                                                    Width="260"/>
                                <DataGridTextColumn Header="TIN"
                                                    Binding="{Binding MaskedTin}"
                                                    Width="130"/>
                                <DataGridTextColumn Header="Total Payments"
                                                    Binding="{Binding TotalPaymentsDisplay}"
                                                    Width="160"/>
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding StatusDisplay}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 1099 Generation Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                            <Button Content="Generate 1099-NECs"
                                    Command="{Binding GenerateOfficial1099sCommand}"
                                    IsEnabled="{Binding !IsGenerating}"
                                    Padding="16,8"
                                    Classes="primary"/>
                            <Button Content="Generate 1096"
                                    Command="{Binding Generate1096Command}"
                                    IsEnabled="{Binding !IsGenerating}"
                                    Padding="16,8"
                                    Classes="secondary"/>
                            <Button Content="Export 1099 IRIS CSV"
                                    Command="{Binding ExportIrisCsvCommand}"
                                    IsEnabled="{Binding !IsGenerating}"
                                    Padding="16,8"
                                    Classes="secondary"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Form 940 (FUTA) Section -->
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Form 940 — Annual FUTA Tax Return" Classes="section-header"/>
                        <TextBlock Text="Federal Unemployment Tax Act (FUTA) annual return — $7,000 wage base per employee at 0.6% net rate" FontSize="13" Foreground="{StaticResource TextMutedBrush}"/>

                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                            <Button Content="Generate Form 940"
                                    Command="{Binding GenerateOfficialForm940Command}"
                                    IsEnabled="{Binding !IsGenerating}"
                                    Padding="16,8"
                                    Classes="primary"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
